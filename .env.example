# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/portfolio

# Auth — use long random strings in production
AUTH_JWT_SECRET=change-me-to-a-long-random-string
OTP_PEPPER=change-me-another-long-random-string

# Cloudinary (profile photos). Create at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional: folder in Cloudinary (no leading or trailing slash)
# CLOUDINARY_AVATAR_FOLDER=portfolio/avatars

# Production email (ignored in development; OTP is logged instead)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Portfolio <noreply@example.com>"
